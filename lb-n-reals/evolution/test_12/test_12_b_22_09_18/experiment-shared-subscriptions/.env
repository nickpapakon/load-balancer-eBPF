# special IPs (VIPs, Local IP for IPIP tunnel, etc)
VIP_SUBNET=10.1.50.0/24
VIP_AB=10.1.50.50
VIP_BC=10.1.50.60
VIP_ALL=10.1.50.100
VIP_A=10.1.50.1
VIP_B=10.1.50.2
VIP_DEFAULT=10.1.50.250
# whenever you change this MQTT_VIP, change it also in katran/lib/bpf/mqtt.h
# IMPORTANT # CHANGE !
MQTT_VIP=10.1.50.200

LOCAL_IP_FOR_IPIP=127.0.0.42

# whenever you change this port, change it also in mosquitto.conf
# IMPORTANT # CHANGE !
MQTT_PORT=1883

KATRAN_INTERFACE=eth0

## Experiment constants
KEEP_ALIVE=4
TOTAL_MESSAGES=30000
SLEEP_TIME=0.01

# publish only to one real
ONE_REAL_ONLY=0

# use Shared Subscriptions (MQTT feature) to load balance among reals
# (Do not use katran LB)
SHARED_SUBS=1

# pause clients after publish
PAUSE=0


# enable bpf_printk of mqtt_fwd bpf prog for debugging (will print to trace pipe)
# CHANGE: for Katran BPF prints, use katran Dockerfiles's ENV ENABLE_KATRAN_BPF_PRINTK instead of this one
ENABLE_BPF_PRINTK=0

# scrape XDP program CPU usage ns  (affects userspace CPU usage due to frequent docker exec...)
SCRAPE_XDP=1

# use simple Katran without mqtt_LB extension
SIMPLE_KATRAN=0